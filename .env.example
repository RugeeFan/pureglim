DATABASE_URL="postgresql://pureglim:pureglim@localhost:5433/pureglim?schema=public"

NOTIFICATION_EMAIL="hello@pureglim.com"
MAIL_FROM="PureGlim <noreply@pureglim.local>"

SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
SMTP_SECURE="false"

# Admin auth
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=   # min 32-char random string, e.g. openssl rand -base64 32
PARTNER_JWT_SECRET= # min 32-char random string, separate from admin

# Set to "true" to disable real email sending (logs to console instead)
EMAIL_DISABLED=

# Twilio Verify
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VERIFY_SERVICE_SID=

# Local development only: when set, SMS verification uses this fixed code instead of calling Twilio
TWILIO_MOCK_OTP_CODE=

# Google Places Autocomplete (booking form address field)
# If not set, the form falls back to plain manual address fields automatically.
#
# IMPORTANT — restrict this key in Google Cloud Console before using in production:
#   1. Application restriction: HTTP referrers only
#      - http://localhost:*/*           (local dev)
#      - https://pureglim.com.au/*
#      - https://www.pureglim.com.au/*
#   2. API restriction: enable only the following APIs for this key:
#      - Maps JavaScript API
#      - Places API  (legacy)  OR  Places API (New)
#   3. Billing: set monthly budget alerts (recommended: AU$10 warning, AU$20 cap)
#
# Google Cloud Console: https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
